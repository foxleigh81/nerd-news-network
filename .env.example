# Copy to .env.local and fill in as needed. All are optional for local dev.

# Absolute site URL (used for canonical URLs, sitemap, RSS, social cards).
NEXT_PUBLIC_SITE_URL=https://www.nerdnewsnetwork.com

# Advertising master switch. Ad placements only render when this is "true"
# (real AdSense units if a client id + slot are set below, otherwise labelled
# placeholders). Leave unset/false to ship the site with no ad space at all.
# NEXT_PUBLIC_ADS_ENABLED=true

# Google AdSense — set the client id to activate live ads (otherwise enabled
# slots show clearly-labelled placeholder ad space).
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_AD_SLOT_LEADER=1234567890          # feed leaderboard (top)
# NEXT_PUBLIC_AD_SLOT_INFEED=1234567891          # in-grid unit replacing a feed card
# NEXT_PUBLIC_AD_SLOT_ARTICLE_TOP=1234567892     # article, above the body
# NEXT_PUBLIC_AD_SLOT_ARTICLE_BOTTOM=1234567893  # article, below the body
# NEXT_PUBLIC_AD_SLOT_SIDEBAR=1234567894         # article sidebar (top)
# NEXT_PUBLIC_AD_SLOT_SIDEBAR_BOTTOM=1234567895  # article sidebar (bottom)

# Google Analytics 4 measurement id. MUST be NEXT_PUBLIC_ (this is a static
# export, so only NEXT_PUBLIC_ vars reach the browser). GA loads in production
# builds only. Leave unset to disable analytics.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Pin the build's "current month" reference (ISO date). Useful for the daily
# task or for reproducible builds. Defaults to the real build time.
# NNN_BUILD_DATE=2026-06-14T09:00:00Z
