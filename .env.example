# Copy to .env.local and fill in as needed. All are optional for local dev.

# Absolute site URL (used for canonical URLs, sitemap, RSS, social cards).
NEXT_PUBLIC_SITE_URL=https://nerdnews.network

# Google AdSense — set the client id to activate live ads (otherwise the site
# shows clearly-labelled placeholder ad space).
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_AD_SLOT_LEADER=1234567890
# NEXT_PUBLIC_AD_SLOT_INFEED=1234567891
# NEXT_PUBLIC_AD_SLOT_SIDEBAR=1234567892

# Pin the build's "current month" reference (ISO date). Useful for the daily
# task or for reproducible builds. Defaults to the real build time.
# NNN_BUILD_DATE=2026-06-14T09:00:00Z
